# Supabase Configuration
# Copy this file to .env and fill in the values from your Supabase project settings

VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Feature Flags
# Set to "true" to enable demo mode with seed/mock data
VITE_DEMO_MODE=false

# E2E Testing (optional - for running Playwright tests)
# PLAYWRIGHT_BASE_URL=http://localhost:8080
# TEST_CUSTOMER_EMAIL=customer.test@bwild.com.br
# TEST_CUSTOMER_PASSWORD=test123456
# TEST_STAFF_EMAIL=staff.test@bwild.com.br
# TEST_STAFF_PASSWORD=test123456
# TEST_PROJECT_ID=

# Seed Script (requires service role key - NEVER commit this)
# SUPABASE_SERVICE_ROLE_KEY=
